# Server Configuration
PORT=3000
NODE_ENV=development

# Image Analysis Agent
IMAGE_AGENT_URL=http://localhost:5000
IMAGE_AGENT_TIMEOUT=30000

# Database Agent
DB_AGENT_URL=http://localhost:5001
DB_AGENT_TIMEOUT=10000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=turtle_id_db

# File Upload
MAX_FILE_SIZE=50mb
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
