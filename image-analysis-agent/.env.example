# Image Analysis Agent Configuration

# Server
PORT=5000
DEBUG=False

# Model
MODEL_PATH=./src/models/weights/best_model.pt
CONFIDENCE_THRESHOLD=0.85

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/image_analysis_agent.log

# Coordinator
COORDINATOR_URL=http://localhost:3000

# Database Agent
DB_AGENT_URL=http://localhost:5001

# Cache
ENABLE_CACHE=True
CACHE_TTL=3600
